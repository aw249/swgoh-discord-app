{
  "name": "swgoh-discord-app",
  "version": "1.0.0",
  "description": "A Discord bot for Star Wars: Galaxy of Heroes, providing roster insights and recommendations",
  "main": "dist/bot/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently --kill-others --names comlink,bot --prefix-colors cyan,green \"npm run comlink\" \"npm run dev:bot\"",
    "dev:bot": "ts-node src/bot/index.ts",
    "comlink": "./bin/swgoh-comlink-4.0.0 --port 3200 --name swgoh-discord-app",
    "start": "node dist/bot/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "deploy:commands": "ts-node src/bot/commandRegistry.ts"
  },
  "keywords": [
    "discord",
    "bot",
    "swgoh",
    "star-wars"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@swgoh-utils/comlink": "^1.4.1",
    "axios": "^1.6.0",
    "canvas": "^3.2.0",
    "cloudscraper": "^4.6.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "puppeteer": "^24.31.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.25",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
