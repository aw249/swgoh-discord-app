# SWGOH Discord Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Discord Configuration (Required)
# ===========================================

# Your Discord bot token from the Discord Developer Portal
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Your Discord application client ID
DISCORD_CLIENT_ID=your_discord_client_id_here

# ===========================================
# SWGOH API Configuration (Required)
# ===========================================

# swgoh.gg API key (if using swgoh.gg integration)
SWGOH_API_KEY=your_swgoh_api_key_here

# ===========================================
# Comlink Configuration (Optional)
# ===========================================

# Comlink server URL (defaults to localhost:3200)
COMLINK_URL=http://localhost:3200

# Comlink access key (if using authenticated Comlink)
# COMLINK_ACCESS_KEY=

# Comlink secret key (if using authenticated Comlink)
# COMLINK_SECRET_KEY=

# ===========================================
# Puppeteer Configuration (Raspberry Pi)
# ===========================================

# Path to Chromium browser on ARM64 Linux
# Uncomment these for Raspberry Pi deployment
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ===========================================
# Logging Configuration (Optional)
# ===========================================

# Set to 'development' to enable debug logging
NODE_ENV=production

# Set to 'debug' to enable verbose logging
# LOG_LEVEL=info
